generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ==== ENUMS ==== */
enum UserRole { CUSTOMER PROVIDER ADMIN }
enum BookingStatus { PENDING CONFIRMED COMPLETED CANCELLED }
enum PaymentStatus { PENDING AUTHORIZED SETTLED REFUNDED FAILED }
enum EscrowStatus { HELD RELEASED REFUNDED }
enum KycStatus { PENDING APPROVED REJECTED }
enum DisputeStatus { OPEN RESOLVED REJECTED }
enum PayoutStatus { PENDING IN_PROGRESS PAID FAILED }
enum MediaType { IMAGE VIDEO }
enum PaymentProvider { MOCK PAYME CLICK TOSS }

/* ==== MODELS ==== */
model User {
  id               String    @id @default(cuid())
  phone            String    @unique
  email            String?   @unique
  passwordHash     String?
  role             UserRole  @default(CUSTOMER)
  firstName        String?
  lastName         String?
  avatarUrl        String?
  language         String?   @default("en")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  provider         Provider?
  services         Service[]       @relation("ServiceOwner")
  bookings         Booking[]       @relation("BookingCustomer")
  reviews          Review[]
  messages         Message[]       @relation("MessageSender")
  receivedMessages Message[]       @relation("MessageRecipient")
  processedPayouts Payout[]        @relation("PayoutAdmin")
  addresses        Address[]
}

model Provider {
  id             String      @id @default(cuid())
  userId         String      @unique
  businessName   String?
  bio            String?
  kycStatus      KycStatus   @default(PENDING)
  kycSubmittedAt DateTime?
  verifiedAt     DateTime?
  kycData        Json?
  headline       String?
  averageRating  Float?      @default(0)
  totalReviews   Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  services    Service[]
  calendars   Calendar[]
  payouts     Payout[]   @relation("PayoutProvider")
  bookings    Booking[]  @relation("ProviderBookings")
  categories  ProviderCategory[]
  reviews     Review[]   // <-- Review.provider ning opposite field'i
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services   Service[]
  providers  ProviderCategory[]
}

model ProviderCategory {
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String

  @@id([providerId, categoryId])
}

model Service {
  id            String    @id @default(cuid())
  providerId    String
  categoryId    String
  ownerId       String
  title         String
  description   String
  coverImageUrl String?
  isPublished   Boolean   @default(false)
  averageRating Float?    @default(0)
  totalReviews  Int       @default(0)
  priceFrom     Decimal?  @db.Decimal(10, 2)
  currency      String    @default("USD")
  latitude      Float?
  longitude     Float?
  addressId     String?
  tags          String[]  @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  provider     Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  owner        User      @relation("ServiceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  category     Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  address      Address?  @relation(fields: [addressId], references: [id], onDelete: SetNull)
  media        ServiceMedia[]
  packages     ServicePackage[]
  availability AvailabilitySlot[]
  bookings     Booking[]
  reviews      Review[]

  @@index([providerId, isPublished])
  @@index([categoryId])
  @@index([latitude, longitude])
  // NOTE: @@fulltext Postgres uchun Prisma’da qo'llanmaydi — olib tashlandi
}

model ServiceMedia {
  id        String    @id @default(cuid())
  serviceId String
  url       String
  type      MediaType @default(IMAGE)
  isPrimary Boolean   @default(false)
  createdAt DateTime  @default(now())

  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model ServicePackage {
  id              String   @id @default(cuid())
  serviceId       String
  name            String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  currency        String   @default("USD")
  durationMinutes Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  service         Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookings        Booking[]
}

model Calendar {
  id         String   @id @default(cuid())
  providerId String
  title      String
  timezone   String   @default("UTC")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  provider   Provider           @relation(fields: [providerId], references: [id], onDelete: Cascade)
  slots      AvailabilitySlot[]
}

model AvailabilitySlot {
  id         String     @id @default(cuid())
  calendarId String
  serviceId  String?
  startTime  DateTime
  endTime    DateTime
  isBooked   Boolean    @default(false)
  createdAt  DateTime   @default(now())

  calendar   Calendar   @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  service    Service?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  // One-to-one with Booking is anchored on Booking.slotId (unique)
  booking    Booking?

  @@index([startTime, endTime])
}

model Booking {
  id              String         @id @default(cuid())
  reference       String         @unique
  customerId      String
  providerId      String
  serviceId       String
  packageId       String
  slotId          String?        @unique        // <-- 1-1 relation uchun unique
  addressId       String?
  status          BookingStatus  @default(PENDING)
  scheduledAt     DateTime
  durationMinutes Int
  notes           String?
  price           Decimal        @db.Decimal(10, 2)
  currency        String         @default("USD")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  cancelledAt     DateTime?
  completedAt     DateTime?

  customer  User             @relation("BookingCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  provider  Provider         @relation("ProviderBookings", fields: [providerId], references: [id], onDelete: Cascade)
  service   Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  package   ServicePackage   @relation(fields: [packageId], references: [id], onDelete: Cascade)
  slot      AvailabilitySlot? @relation(fields: [slotId], references: [id], onDelete: SetNull)
  address   Address?         @relation(fields: [addressId], references: [id], onDelete: SetNull)
  payment   Payment?
  escrow    Escrow?
  review    Review?
  messages  Message[]
  dispute   Dispute?

  @@index([customerId, status])
  @@index([providerId, status])
}

model Payment {
  id             String          @id @default(cuid())
  bookingId      String          @unique
  amount         Decimal         @db.Decimal(10, 2)
  currency       String          @default("USD")
  status         PaymentStatus   @default(PENDING)
  provider       PaymentProvider @default(MOCK)
  transactionRef String?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  booking        Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  escrow         Escrow?
}

model Escrow {
  id         String       @id @default(cuid())
  bookingId  String       @unique
  paymentId  String?      @unique
  status     EscrowStatus @default(HELD)
  heldAt     DateTime     @default(now())
  releasedAt DateTime?
  refundedAt DateTime?

  booking    Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payment    Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  customerId String
  providerId String
  serviceId  String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer   User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Message {
  id           String   @id @default(cuid())
  bookingId    String
  senderId     String
  recipientId  String
  content      String
  createdAt    DateTime @default(now())
  readAt       DateTime?

  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
}

model Dispute {
  id         String        @id @default(cuid())
  bookingId  String        @unique
  status     DisputeStatus @default(OPEN)
  reason     String
  resolution String?
  createdAt  DateTime      @default(now())
  resolvedAt DateTime?

  booking    Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Payout {
  id          String       @id @default(cuid())
  providerId  String
  amount      Decimal      @db.Decimal(10, 2)
  currency    String       @default("USD")
  status      PayoutStatus @default(PENDING)
  scheduledAt DateTime?
  paidAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  processedBy String?

  provider  Provider @relation("PayoutProvider", fields: [providerId], references: [id], onDelete: Cascade)
  admin     User?    @relation("PayoutAdmin", fields: [processedBy], references: [id], onDelete: SetNull)
}

model Address {
  id         String    @id @default(cuid())
  userId     String?
  label      String?
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String?
  country    String
  latitude   Float?
  longitude  Float?
  isPrimary  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  services  Service[]
  bookings  Booking[]

  @@index([latitude, longitude])
}
